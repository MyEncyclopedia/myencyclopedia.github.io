digraph G {
    rankdir=LR; 
    "s" [label="s" color=red style=filled];
    "s_prime_1" [label="s'1" color=brown style=filled];
    "s_prime_2" [label="s'2" color=brown style=filled];
    "p1" [label="p1" color=grey style=filled];
    "p2" [label="p2" color=grey style=filled];

    s -> s_prime_1;
    s -> s_prime_2;
    p1-> s;
    p2-> s;
}
