strict digraph {
    
    Start [shape="ellipse" style="filled" fillcolor="#E0E000" label="Start +2"]
    
    AC [shape="ellipse" style="filled" fillcolor="#1be817"]

    REJ [shape="ellipse" style="filled" fillcolor="#a2a199"]



    Start -> AC [xlabel="40/49" pos="0,100"]
    Start -> REJ  [label="9/49"]
    REJ Start
    REJ -> Start [ style=dashed]
}
